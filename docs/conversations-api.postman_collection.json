{
  "info": {
    "name": "conversations gem API",
    "description": "Postman collection generated from conversations gem engine routes and controllers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "target_account_id",
      "value": "123"
    },
    {
      "key": "max_id",
      "value": ""
    },
    {
      "key": "since_id",
      "value": ""
    },
    {
      "key": "min_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Check Conversation",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/patchwork/conversations/check_conversation?target_account_id={{target_account_id}}&max_id={{max_id}}&since_id={{since_id}}&min_id={{min_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "patchwork",
            "conversations",
            "check_conversation"
          ],
          "query": [
            {
              "key": "target_account_id",
              "value": "{{target_account_id}}",
              "description": "Required target account identifier"
            },
            {
              "key": "max_id",
              "value": "{{max_id}}",
              "description": "Optional pagination cursor"
            },
            {
              "key": "since_id",
              "value": "{{since_id}}",
              "description": "Optional pagination cursor"
            },
            {
              "key": "min_id",
              "value": "{{min_id}}",
              "description": "Optional pagination cursor"
            }
          ]
        },
        "description": "Controller: Conversations::Api::V1::Patchwork::ConversationsController#check_conversation\\nAuth: Required (doorkeeper scopes read/read:statuses + require_user!)."
      },
      "response": []
    },
    {
      "name": "Read All Conversations",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/patchwork/conversations/read_all",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "patchwork",
            "conversations",
            "read_all"
          ]
        },
        "description": "Controller: Conversations::Api::V1::Patchwork::ConversationsController#read_all\\nAuth: Required (doorkeeper scopes write/write:conversations + require_user!)."
      },
      "response": []
    }
  ]
}
