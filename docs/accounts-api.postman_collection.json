        {
          "name": "Verify OTP",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"token-or-reset-token\",\n  \"otp_secret\": \"1234\",\n  \"is_reset_password\": true,\n  \"is_change_email\": false,\n  \"invitation_code\": \"\",\n  \"skip_waitlist\": false,\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/custom_passwords/verify_otp",
              "host": [
