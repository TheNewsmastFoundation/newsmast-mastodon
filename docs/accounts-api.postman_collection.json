                "v1",
                "custom_passwords",
                "verify_otp"
              ]
            }
          }
        },
        {
          "name": "Request OTP",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/custom_passwords/request_otp?id=token-or-reset-token&email=user@example.com",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "custom_passwords",
                "request_otp"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "token-or-reset-token"
                },
                {
                  "key": "email",
                  "value": "user@example.com"
                }
              ]
            }
          }
        },
